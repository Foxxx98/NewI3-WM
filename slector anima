#!/usr/bin/env python3

import os
import random
import subprocess

STATIC_DIR = os.path.expanduser(
    "~/wallpaper_colors_static"
)

ENGINE_DIR = os.path.expanduser(
    "~/wallpaper_colors_engine"
)

STATIC_WALLPAPER_FOLDER = os.path.expanduser(
    "~/Pictures/Wallpapers"
)

WORKSHOP_DIR = os.path.expanduser(
    "~/.steam/steam/steamapps/workshop/content/431960"
)

def get_available_colors():

    static_colors = set(
        f.replace(".txt", "")
        for f in os.listdir(STATIC_DIR)
        if f.endswith(".txt")
    )

    engine_colors = set(
        f.replace(".txt", "")
        for f in os.listdir(ENGINE_DIR)
        if f.endswith(".txt")
    )

    return sorted(static_colors & engine_colors)

def rofi_select(options):

    rofi_input = "\n".join(options)

    result = subprocess.run(
        ["rofi", "-dmenu", "-p", "Wallpaper Color"],
        input=rofi_input,
        text=True,
        capture_output=True
    )

    return result.stdout.strip()

def random_from_file(path):

    with open(path, "r") as f:
        lines = [
            line.strip()
            for line in f.readlines()
            if line.strip()
        ]

    return random.choice(lines)

colors = get_available_colors()

if not colors:
    exit()

selected_color = rofi_select(colors)

if not selected_color:
    exit()

static_wallpaper = random_from_file(
    os.path.join(
        STATIC_DIR,
        f"{selected_color}.txt"
    )
)

engine_wallpaper = random_from_file(
    os.path.join(
        ENGINE_DIR,
        f"{selected_color}.txt"
    )
)

static_path = os.path.join(
    STATIC_WALLPAPER_FOLDER,
    static_wallpaper
)

engine_path = os.path.join(
    WORKSHOP_DIR,
    engine_wallpaper
)

subprocess.run([
    "feh",
    "--bg-fill",
    static_path
])

subprocess.Popen([
    "linux-wallpaperengine",
    "--screen-root",
    "DP-1",
    engine_path
])
