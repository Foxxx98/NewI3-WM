#!/usr/bin/env python3

import os
from collections import Counter
from PIL import Image

# =========================
# CONFIG
# =========================

WORKSHOP_DIR = os.path.expanduser(
    "~/.steam/steam/steamapps/workshop/content/431960"
)

OUTPUT_DIR = os.path.expanduser(
    "~/wallpaper_colors_engine"
)

# =========================

os.makedirs(OUTPUT_DIR, exist_ok=True)

COLOR_MAP = {
    "red": (255, 0, 0),
    "green": (0, 255, 0),
    "blue": (0, 0, 255),
    "yellow": (255, 255, 0),
    "purple": (128, 0, 128),
    "cyan": (0, 255, 255),
    "orange": (255, 165, 0),
    "pink": (255, 105, 180),
    "white": (255, 255, 255),
    "black": (0, 0, 0),
}

def closest_color(rgb):
    r, g, b = rgb

    closest = None
    min_distance = 999999

    for color_name, color_rgb in COLOR_MAP.items():
        cr, cg, cb = color_rgb

        distance = (
            (r - cr) ** 2 +
            (g - cg) ** 2 +
            (b - cb) ** 2
        )

        if distance < min_distance:
            min_distance = distance
            closest = color_name

    return closest

def dominant_color(image_path):
    img = Image.open(image_path).convert("RGB")
    img = img.resize((100, 100))

    pixels = list(img.getdata())

    dominant = Counter(pixels).most_common(1)[0][0]

    return dominant

for workshop_id in os.listdir(WORKSHOP_DIR):

    wallpaper_path = os.path.join(
        WORKSHOP_DIR,
        workshop_id
    )

    if not os.path.isdir(wallpaper_path):
        continue

    preview = None

    for possible in [
        "preview.jpg",
        "preview.png",
        "project.jpg",
        "thumbnail.jpg"
    ]:

        possible_path = os.path.join(
            wallpaper_path,
            possible
        )

        if os.path.exists(possible_path):
            preview = possible_path
            break

    if not preview:
        continue

    try:
        rgb = dominant_color(preview)
        category = closest_color(rgb)

        output_file = os.path.join(
            OUTPUT_DIR,
            f"{category}.txt"
        )

        with open(output_file, "a") as f:
            f.write(workshop_id + "\n")

        print(f"[OK] {workshop_id} -> {category}")

    except Exception as e:
        print(f"[ERROR] {workshop_id}: {e}")
