#!/usr/bin/env python3

import os
import json
from collections import Counter
from PIL import Image

# =========================
# CONFIG
# =========================

WALLPAPER_DIR = os.path.expanduser("~/Pictures/Wallpapers")
OUTPUT_DIR = os.path.expanduser("~/wallpaper_colors_static")

# =========================

os.makedirs(OUTPUT_DIR, exist_ok=True)

COLOR_MAP = {
    "red": (255, 0, 0),
    "green": (0, 255, 0),
    "blue": (0, 0, 255),
    "yellow": (255, 255, 0),
    "purple": (128, 0, 128),
    "cyan": (0, 255, 255),
    "orange": (255, 165, 0),
    "pink": (255, 105, 180),
    "white": (255, 255, 255),
    "black": (0, 0, 0),
}

def closest_color(rgb):
    r, g, b = rgb

    closest = None
    min_distance = 999999

    for color_name, color_rgb in COLOR_MAP.items():
        cr, cg, cb = color_rgb

        distance = (
            (r - cr) ** 2 +
            (g - cg) ** 2 +
            (b - cb) ** 2
        )

        if distance < min_distance:
            min_distance = distance
            closest = color_name

    return closest

def dominant_color(image_path):
    img = Image.open(image_path).convert("RGB")
    img = img.resize((100, 100))

    pixels = list(img.getdata())

    dominant = Counter(pixels).most_common(1)[0][0]

    return dominant

for file in os.listdir(WALLPAPER_DIR):

    if not file.lower().endswith((
        ".jpg",
        ".jpeg",
        ".png",
        ".webp"
    )):
        continue

    path = os.path.join(WALLPAPER_DIR, file)

    try:
        rgb = dominant_color(path)
        category = closest_color(rgb)

        output_file = os.path.join(
            OUTPUT_DIR,
            f"{category}.txt"
        )

        with open(output_file, "a") as f:
            f.write(file + "\n")

        print(f"[OK] {file} -> {category}")

    except Exception as e:
        print(f"[ERROR] {file}: {e}")
